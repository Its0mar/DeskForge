### Variable Definitions
@base_url = http://localhost:5098
@tenant_code = TECH-CORE
@owner_email = admin@techcore.com
@staff_email = omar@techcore.com
@password = pass1234

### 1. Register a New Organization (Run once)
POST {{base_url}}/api/auth/organization/register
Content-Type: application/json

{
  "name": "Tech Core Solutions",
  "userName": "admin_tech",
  "firstName": "Admin",
  "lastName": "User",
  "tenantCode": "{{tenant_code}}",
  "email": "{{owner_email}}",
  "password": "{{password}}"
}

> {% client.global.set("auth_token", response.body.accessToken); %}
> {% client.global.set("refresh_token", response.body.refreshToken); %}

### 2. Login (To get fresh Token)
# @name login
POST {{base_url}}/api/auth/login
Content-Type: application/json

{
  "identifier": "{{owner_email}}",
  "password": "{{password}}"
}

> {% client.global.set("auth_token", response.body.accessToken); %}
> {% client.global.set("refresh_token", response.body.refreshToken); %}

### 3. Get My Profile
GET {{base_url}}/api/auth/profile
Authorization: Bearer {{auth_token}}

### 4. Create a Team (e.g., Support Team)
# @name createTeam
POST {{base_url}}/api/teams
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "name": "Hardware Support",
  "description": "Handles all physical hardware issues"
}

> {% client.global.set("team_id", response.body); %}

### 5. Get Teams (Verify creation)
GET {{base_url}}/api/teams
Authorization: Bearer {{auth_token}}

### 6. Create SLA Policies (Required for Ticket logic)
# Create HIGH priority policy (Priority 3 - verify your Enum value)
POST {{base_url}}/api/sla
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "priority": 3,
  "responseMinutes": 60,
  "resolutionMinutes": 240
}

### 7. Create a Category and Map to Team
# @name createCategory
POST {{base_url}}/api/categories
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "name": "Laptop Repair",
  "description": "Screen, keyboard, or battery issues",
  "targetTeamId": "{{team_id}}"
}

> {% client.global.set("category_id", response.body); %}

### 8. GET Categories (Verify Mapping)
GET {{base_url}}/api/categories
Authorization: Bearer {{auth_token}}

### 9. CREATE TICKET (The Big One)
# This will trigger your AutoAssignHandler in the background!
POST {{base_url}}/api/tickets
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "title": "Broken MacBook Screen",
  "description": "The screen is flickering and showing green lines after the update.",
  "priority": 3,
  "categoryId": "{{category_id}}"
}

### 10. Invite an Employee
POST {{base_url}}/api/organizations/invite-employee
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "email": "{{staff_email}}",
  "role": 1
}

### 11. Refresh Token
POST {{base_url}}/api/auth/refresh
Content-Type: application/json

{
  "accessToken": "{{auth_token}}",
  "refreshToken": "{{refresh_token}}"
}

### 12. Logout
POST {{base_url}}/api/auth/logout
Content-Type: application/json

{
  "refreshToken": "{{refresh_token}}"
}